# Auto detect text files and perform LF normalization on check-in
* text=auto

# Source code files - normalize and checkout with LF
*.java text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.sh text eol=lf

# Documentation files
*.md text eol=lf
LICENSE text eol=lf

# Config files
.gitignore text eol=lf
.gitattributes text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.zip binary
