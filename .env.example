# Database Configuration
DB_NAME=pricepilot
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Redis Memory Protection
REDIS_MAX_MEMORY=256mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# AI Service Configuration
AI_PORT=8000
PRICEPILOT_AI_API_KEY=your-secure-api-key
PRICEPILOT_AI_URL=http://pricepilot-ai:8000

# Backend Service Configuration
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod
PRICEPILOT_JWT_SECRET=your-base64-encoded-jwt-signing-key

# Frontend Service Configuration
FRONTEND_PORT=80
VITE_API_BASE_URL=http://localhost:8080/api/v1

# CORS Configuration
PRICEPILOT_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000
